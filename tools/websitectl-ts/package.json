{
  "name": "websitectl",
  "version": "0.1.0",
  "description": "CLI for managing website admin APIs",
  "type": "module",
  "bin": {
    "websitectl": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build",
    "install:global": "npm run build && npm i -g .",
    "publish:npm": "npm run build && npm publish --access public",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.4",
    "commander": "^14.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
